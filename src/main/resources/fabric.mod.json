{
  "schemaVersion": 1,
  "id": "mcduelstagger",
  "version": "${version}",
  "name": "MCDuels Rank Tagger",
  "description": "Shows MCDuels ranks above player nametags.",
  "authors": ["baldzika"],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client":  ["com.mcduelstagger.ModEntry"],
    "modmenu": ["com.mcduelstagger.config.ModMenuEntry"]
  },
  "mixins": [
    { "config": "mcduelstagger.mixins.json", "environment": "client" }
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.4",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*",
    "cloth-config": "*"
  }
}
